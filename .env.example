# ---------------------------------------------------------------------------
# Elite Events LA — Operations OS environment variables
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# ---------------------------------------------------------------------------

# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Accepts the project's anon / publishable key (sb_publishable_... or legacy anon JWT)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — SERVER ONLY. Bypasses RLS. Never prefix with NEXT_PUBLIC.
# Used by the Stripe webhook to write payment status. Get it from the dashboard:
# Project Settings → API → service_role / secret key.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe — SERVER ONLY
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` (local) or the Stripe dashboard webhook endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend — SERVER ONLY (transactional email; can reuse the shared Resend account)
RESEND_API_KEY=re_...
# Verified sender for outbound mail
RESEND_FROM_EMAIL="Elite Events LA <ops@eliteeventsla.com>"

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Client invoice pages (/i/<token>) — all OPTIONAL, SERVER ONLY.
# Global alternative-payment instructions shown on the public invoice + PDF.
# A method appears only if its var is set. Use "\n" for multi-line details.
# ---------------------------------------------------------------------------
PAYMENT_ZELLE="Zelle to billing@eliteeventsla.com"
PAYMENT_WIRE="Bank: ...\nRouting: ...\nAccount: ...\nName on account: Elite Events LA"
PAYMENT_CHECK="Payable to: Elite Events LA\nMail to: 123 ... , Los Angeles, CA 900xx"
PAYMENT_INSTRUCTIONS_NOTE="Please include your invoice number with payment."

# Business identity on client invoices (optional overrides)
COMPANY_EMAIL=ops@eliteeventsla.com
COMPANY_PHONE=
COMPANY_ADDRESS=
